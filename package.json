{
  "name": "@betterdiscord/cli",
  "version": "0.0.0",
  "description": "A macOS Big Sur-focused CLI for managing BetterDiscord on older Intel Macs",
  "main": "index.js",
  "keywords": ["discord", "betterdiscord", "cli", "tool", "installer"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "postinstall": "go-npm install",
    "preuninstall": "go-npm uninstall"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XxUnkn0wnxX/BDCLI.git"
  },
  "author": "BetterDiscord Team",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/XxUnkn0wnxX/BDCLI/issues"
  },
  "homepage": "https://github.com/XxUnkn0wnxX/BDCLI#readme",
  "dependencies": {
    "@go-task/go-npm": "^0.2.0"
  },
  "goBinary": {
    "name": "bdcli",
    "path": "./bin",
    "url": "https://github.com/XxUnkn0wnxX/BDCLI/releases/download/v{{version}}/bdcli_{{version}}_{{platform}}_{{arch}}_macos11{{archive_ext}}"
  }
}
